PORT=4000
FRONTEND_URL=http://localhost:5173
SESSION_SECRET=replace-with-a-strong-secret
ALLOWED_EMAIL_DOMAIN=studiolabs.com

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=ims

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

JIRA_CLIENT_ID=your-atlassian-client-id
JIRA_CLIENT_SECRET=your-atlassian-client-secret
JIRA_CALLBACK_URL=http://localhost:4000/api/auth/jira/callback
JIRA_AUTH_URL=https://auth.atlassian.com/authorize
JIRA_TOKEN_URL=https://auth.atlassian.com/oauth/token
JIRA_PROJECT_ISSUES_SYNC_CONCURRENCY=3
JIRA_USERS_SYNC_CRON=15 2 * * *
JIRA_USERS_SYNC_CRON_ENABLED=true
JIRA_USERS_SYNC_RUN_ON_STARTUP=false

TEMPO_API_BASE_URL=https://api.tempo.io/4
TEMPO_API_TOKEN=your-tempo-api-token
TEMPO_PAGE_LIMIT=50
TEMPO_ACCOUNTS_SYNC_CRON=0 2 * * *
TEMPO_ACCOUNTS_SYNC_CRON_ENABLED=true
TEMPO_ACCOUNTS_SYNC_RUN_ON_STARTUP=false
